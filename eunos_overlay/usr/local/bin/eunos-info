#!/bin/sh
# eunos-info - EunOS System Information

CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
WHITE='\033[1;37m'
RED='\033[0;31m'
BOLD='\033[1m'
NC='\033[0m'

bar() {
    PCT="$1"
    WIDTH=30
    FILLED=$((PCT * WIDTH / 100))
    EMPTY=$((WIDTH - FILLED))
    printf "["
    i=0
    while [ "$i" -lt "$FILLED" ]; do printf "█"; i=$((i+1)); done
    while [ "$i" -lt "$WIDTH" ]; do printf "░"; i=$((i+1)); done
    printf "] %d%%" "$PCT"
}

echo ""
printf "${BOLD}${CYAN}  ╔══════════════════════════════════════╗${NC}\n"
printf "${BOLD}${CYAN}  ║  ${WHITE}EunOS System Information${CYAN}            ║${NC}\n"
printf "${BOLD}${CYAN}  ╚══════════════════════════════════════╝${NC}\n"
echo ""

# OS info
printf "  ${YELLOW}OS:${NC}       "
if [ -f /etc/os-release ]; then
    . /etc/os-release
    printf "%s %s\n" "${PRETTY_NAME:-EunOS}" "${VERSION_ID:-1.0.0}"
else
    uname -s -r
fi

# Kernel
printf "  ${YELLOW}Kernel:${NC}   %s\n" "$(uname -r 2>/dev/null || echo 'Unknown')"

# Architecture
printf "  ${YELLOW}Arch:${NC}     %s\n" "$(uname -m 2>/dev/null || echo 'x86_64')"

# Hostname
printf "  ${YELLOW}Hostname:${NC} %s\n" "$(hostname 2>/dev/null || echo 'eunos')"

# Uptime
printf "  ${YELLOW}Uptime:${NC}   %s\n" "$(uptime 2>/dev/null | sed 's/.*up //' | sed 's/,.*//' || echo 'Unknown')"

echo ""

# CPU info
printf "  ${GREEN}CPU:${NC}\n"
if [ -f /proc/cpuinfo ]; then
    CPU_MODEL=$(grep 'model name' /proc/cpuinfo | head -1 | cut -d: -f2 | sed 's/^ //')
    CPU_CORES=$(grep -c '^processor' /proc/cpuinfo 2>/dev/null || echo 1)
    printf "    Model: %s\n" "${CPU_MODEL:-Unknown}"
    printf "    Cores: %s cores\n" "$CPU_CORES"
else
    printf "    No info\n"
fi

# Load average
if [ -f /proc/loadavg ]; then
    LOAD=$(cat /proc/loadavg | awk '{print $1, $2, $3}')
    printf "    Load: %s (1min 5min 15min)\n" "$LOAD"
fi

echo ""

# Memory
printf "  ${BLUE}Memory:${NC}\n"
if [ -f /proc/meminfo ]; then
    MEM_TOTAL=$(grep '^MemTotal:' /proc/meminfo | awk '{print $2}')
    MEM_FREE=$(grep '^MemFree:' /proc/meminfo | awk '{print $2}')
    MEM_BUFFERS=$(grep '^Buffers:' /proc/meminfo | awk '{print $2}')
    MEM_CACHED=$(grep '^Cached:' /proc/meminfo | awk '{print $2}')
    MEM_AVAIL=$(grep '^MemAvailable:' /proc/meminfo | awk '{print $2}')

    MEM_USED=$((MEM_TOTAL - MEM_FREE - MEM_BUFFERS - MEM_CACHED))
    [ "$MEM_USED" -lt 0 ] && MEM_USED=0
    MEM_PCT=$((MEM_USED * 100 / MEM_TOTAL))

    printf "    Total: %dMB\n" "$((MEM_TOTAL / 1024))"
    printf "    Used: %dMB  Available: %dMB\n" "$((MEM_USED / 1024))" "$((MEM_AVAIL / 1024))"
    printf "    "
    bar "$MEM_PCT"
    echo ""
fi

echo ""

# Disk
printf "  ${YELLOW}Disk:${NC}\n"
df -h 2>/dev/null | grep -v tmpfs | grep -v udev | tail -n +2 | while read -r FS SIZE USED AVAIL PCT MOUNT; do
    printf "    %-20s %s / %s (%s)\n" "$MOUNT" "$USED" "$SIZE" "$PCT"
done

echo ""

# Network
printf "  ${CYAN}Network:${NC}\n"
if command -v ip >/dev/null 2>&1; then
    ip addr 2>/dev/null | grep 'inet ' | grep -v 'host lo' | while read -r _ ADDR _; do
        printf "    IP: %s\n" "$ADDR"
    done
elif command -v ifconfig >/dev/null 2>&1; then
    ifconfig 2>/dev/null | grep 'inet ' | grep -v '127.0.0.1' | while read -r _ ADDR _; do
        printf "    IP: %s\n" "$ADDR"
    done
else
    printf "    (No network info)\n"
fi

echo ""
