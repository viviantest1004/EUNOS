#!/bin/sh
# EunOS Calculator - basic operations + current time display

C_BOX='\033[1;36m'
C_TITLE='\033[1;37m'
C_OK='\033[1;32m'
C_WARN='\033[1;33m'
C_ERR='\033[1;31m'
C_DIM='\033[2;37m'
C_ACCENT='\033[1;35m'
NC='\033[0m'

HISTORY=""
LAST_RESULT="0"

draw_calc() {
    clear
    NOW=$(date '+%Y-%m-%d')
    TIME=$(date '+%H:%M:%S')
    printf "${C_BOX}"
    printf "╔══════════════════════════════════════╗\n"
    printf "║     ${C_TITLE}EunOS Calculator${C_BOX}                  ║\n"
    printf "╠══════════════════════════════════════╣\n"
    printf "║  ${C_DIM}Date:${C_ACCENT} %-10s${C_BOX}                  ║\n" "$NOW"
    printf "║  ${C_DIM}Time:${C_ACCENT} %-8s${C_BOX}  (24-hour format)  ║\n" "$TIME"
    printf "╠══════════════════════════════════════╣\n"
    printf "║                                      ║\n"
    # Recent calculation history (last 4 lines)
    if [ -n "$HISTORY" ]; then
        echo "$HISTORY" | tail -4 | while IFS= read -r line; do
            printf "║  ${C_DIM}%-36s${C_BOX}║\n" "$line"
        done
    else
        printf "║  ${C_DIM}No calculation history.${C_BOX}            ║\n"
        printf "║                                      ║\n"
        printf "║                                      ║\n"
        printf "║                                      ║\n"
    fi
    printf "║                                      ║\n"
    printf "╠══════════════════════════════════════╣\n"
    printf "║  ${C_OK}Result: %-30s${C_BOX}║\n" "$LAST_RESULT"
    printf "╠══════════════════════════════════════╣\n"
    printf "║  ${C_DIM}Operations: + - * /  e.g. 10 * 3.5${C_BOX} ║\n"
    printf "║  ${C_DIM}Use previous result: ans  e.g. ans+5${C_BOX}║\n"
    printf "║  ${C_DIM}Exit: q${C_BOX}                             ║\n"
    printf "╚══════════════════════════════════════╝\n"
    printf "${NC}"
}

calculate() {
    EXPR="$1"
    # Replace 'ans' with previous result
    EXPR=$(echo "$EXPR" | sed "s/ans/$LAST_RESULT/g")
    # Calculate with bc (supports decimals)
    if command -v bc > /dev/null 2>&1; then
        RESULT=$(echo "scale=10; $EXPR" | bc 2>/dev/null)
        # Remove unnecessary trailing zeros
        RESULT=$(echo "$RESULT" | sed 's/\.\{0,1\}0\+$//')
    else
        # Use expr (integers only) if bc is unavailable
        CLEAN=$(echo "$EXPR" | tr -d ' ')
        RESULT=$(expr "$CLEAN" 2>/dev/null)
    fi
    echo "$RESULT"
}

while true; do
    draw_calc
    printf "  ${C_ACCENT}Enter expression: ${NC}"
    read -r input

    case "$input" in
        [qQ]|exit|quit)
            clear
            printf "${C_OK}  Exiting calculator.${NC}\n\n"
            exit 0
            ;;
        "")
            continue
            ;;
        *)
            # Input validation (allow only numbers, operators, spaces, parentheses, decimals, ans)
            CLEAN=$(echo "$input" | sed "s/ans//g" | tr -d '0-9+\-*/().% ')
            if [ -n "$CLEAN" ]; then
                printf "  ${C_ERR}Invalid input. Use numbers and +,-,*,/ only.${NC}\n"
                sleep 1
                continue
            fi

            RES=$(calculate "$input")
            if [ -z "$RES" ] || echo "$RES" | grep -q "error\|syntax"; then
                printf "  ${C_ERR}Calculation error: Check your expression.${NC}\n"
                sleep 1
            else
                LAST_RESULT="$RES"
                HISTORY="${HISTORY}${input} = ${RES}
"
            fi
            ;;
    esac
done
