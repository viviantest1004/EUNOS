#!/bin/sh
# eunos-install - EunOS package install helper

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
CYAN='\033[0;36m'
NC='\033[0m'

usage() {
    echo "Usage: eunos-install <package> [package...]"
    echo "       eunos-install --list   main package list"
    exit 1
}

list_packages() {
    cat << 'EOF'
EunOS main packages:

  Media:
    mpv           Video/audio player
    feh           Image viewer
    mupdf         PDF viewer

  File formats:
    unzip         ZIP extraction
    p7zip         7-Zip
    unrar         RAR extraction
    sqlite        SQLite database

  Windows compatible:
    wine          Run Windows EXE

  Network:
    curl          HTTP client
    wget          File download
    openssh       SSH

  Development:
    python3       Python 3
    nodejs        Node.js
    git           Version control

  Install example: eunos-install mpv feh
EOF
    exit 0
}

install_pkg() {
    PKG="$1"
    printf "${CYAN}[EunOS]${NC} Installing: ${YELLOW}%s${NC}\n" "$PKG"

    # Use apk if available (Alpine)
    if command -v apk >/dev/null 2>&1; then
        apk add "$PKG"
        return $?
    fi

    # Use apt if available
    if command -v apt-get >/dev/null 2>&1; then
        apt-get install -y "$PKG"
        return $?
    fi

    echo "  Package manager not found."
    return 1
}

[ $# -eq 0 ] && usage

case "$1" in
    --list|-l) list_packages ;;
    --help|-h) usage ;;
esac

# Update package index first
if command -v apk >/dev/null 2>&1; then
    printf "${CYAN}[EunOS]${NC} Updating package index...\n"
    apk update 2>/dev/null
fi

FAILED=0
for PKG in "$@"; do
    install_pkg "$PKG" || FAILED=$((FAILED + 1))
done

if [ "$FAILED" -eq 0 ]; then
    printf "\n${GREEN}All packages installed!${NC}\n"
else
    printf "\n${RED}%d package(s) failed to install${NC}\n" "$FAILED"
fi
