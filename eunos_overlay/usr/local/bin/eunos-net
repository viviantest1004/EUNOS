#!/bin/sh
# eunos-net - EunOS Network Connect

GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo ""
printf "${YELLOW}  Connecting to network...${NC}\n"

connected=0
for iface in eth0 eth1 ens3 ens4 enp0s3 enp0s4; do
    if ip link show "$iface" 2>/dev/null | grep -q "state"; then
        ip link set "$iface" up 2>/dev/null
        if udhcpc -i "$iface" -q -n 2>/dev/null; then
            IP=$(ip addr show "$iface" 2>/dev/null | grep "inet " | awk '{print $2}')
            printf "${GREEN}  Connected!  Interface: $iface  IP: $IP${NC}\n"
            connected=1
            break
        fi
    fi
done

if [ "$connected" = "0" ]; then
    printf "${RED}  Connection failed. Check cable or network.${NC}\n"
    echo "  Try: ip link show"
fi
echo ""
