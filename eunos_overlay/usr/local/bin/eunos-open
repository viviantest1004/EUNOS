#!/bin/sh
# eunos-open - EunOS auto file open (50+ format support)

VERSION="1.0.0"

usage() {
    echo "Usage: eunos-open <file> [file...]"
    echo "       eunos-open --list    supported format list"
    exit 1
}

list_formats() {
    cat << 'EOF'
EunOS supported file formats:
  Executable: ELF, PE/EXE, DLL, COM, SH, PY, RB, PL
  Documents:  TXT, PDF, HTML, XML, JSON, YAML, CSV, MD
  Images:     PNG, JPEG, GIF, BMP, TIFF, ICO, SVG, WEBP
  Audio:      MP3, FLAC, OGG, WAV, AAC, M4A, WMA, OPUS
  Video:      MP4, MKV, AVI, MOV, FLV, WEBM, TS, M2TS
  Archives:   ZIP, TAR, GZ, BZ2, XZ, 7Z, RAR, LZ4
  Data:       SQLite, LevelDB, BIN, ISO, IMG
  Source code: C, C++, Java, Go, Rust, TS, JS, CSS, PHP
EOF
    exit 0
}

# Detect file type by magic bytes
detect_type() {
    FILE="$1"
    [ ! -f "$FILE" ] && echo "ERROR: File not found: $FILE" >&2 && return 1

    # Check file size
    SIZE=$(wc -c < "$FILE" 2>/dev/null || echo 0)

    # Read magic bytes (first 16 bytes as hex)
    MAGIC=$(dd if="$FILE" bs=1 count=16 2>/dev/null | od -A n -t x1 | tr -d ' \n')

    # ELF (Linux executable)
    case "$MAGIC" in
        7f454c46*)
            echo "ELF"
            return ;;
    esac

    # PE/EXE (Windows executable)
    case "$MAGIC" in
        4d5a*)
            echo "EXE"
            return ;;
    esac

    # PDF
    case "$MAGIC" in
        25504446*)
            echo "PDF"
            return ;;
    esac

    # PNG
    case "$MAGIC" in
        89504e47*)
            echo "PNG"
            return ;;
    esac

    # JPEG
    case "$MAGIC" in
        ffd8ff*)
            echo "JPEG"
            return ;;
    esac

    # GIF
    case "$MAGIC" in
        47494638*)
            echo "GIF"
            return ;;
    esac

    # BMP
    case "$MAGIC" in
        424d*)
            echo "BMP"
            return ;;
    esac

    # TIFF (little endian)
    case "$MAGIC" in
        49492a00*)
            echo "TIFF"
            return ;;
    esac

    # TIFF (big endian)
    case "$MAGIC" in
        4d4d002a*)
            echo "TIFF"
            return ;;
    esac

    # WEBP (RIFF....WEBP)
    case "$MAGIC" in
        52494646????????57454250*)
            echo "WEBP"
            return ;;
    esac

    # MP3 (ID3 tag)
    case "$MAGIC" in
        494433*)
            echo "MP3"
            return ;;
    esac

    # MP3 (frame sync)
    case "$MAGIC" in
        fffb*|fff3*|fff2*)
            echo "MP3"
            return ;;
    esac

    # FLAC
    case "$MAGIC" in
        664c6143*)
            echo "FLAC"
            return ;;
    esac

    # OGG
    case "$MAGIC" in
        4f676753*)
            echo "OGG"
            return ;;
    esac

    # WAV (RIFF....WAVE)
    case "$MAGIC" in
        52494646????????57415645*)
            echo "WAV"
            return ;;
    esac

    # MP4 (ftyp)
    MAGIC20=$(dd if="$FILE" bs=1 count=20 2>/dev/null | od -A n -t x1 | tr -d ' \n')
    case "$MAGIC20" in
        ????????6674797069736f6d*|????????667479706d703432*|????????6674797033677035*)
            echo "MP4"
            return ;;
    esac

    # MKV (Matroska)
    case "$MAGIC" in
        1a45dfa3*)
            echo "MKV"
            return ;;
    esac

    # AVI (RIFF....AVI )
    case "$MAGIC" in
        52494646????????41564920*)
            echo "AVI"
            return ;;
    esac

    # ZIP
    case "$MAGIC" in
        504b0304*|504b0506*|504b0708*)
            echo "ZIP"
            return ;;
    esac

    # GZIP
    case "$MAGIC" in
        1f8b*)
            echo "GZIP"
            return ;;
    esac

    # BZIP2
    case "$MAGIC" in
        425a68*)
            echo "BZIP2"
            return ;;
    esac

    # XZ
    case "$MAGIC" in
        fd377a585a00*)
            echo "XZ"
            return ;;
    esac

    # 7-Zip
    case "$MAGIC" in
        377abcaf271c*)
            echo "7Z"
            return ;;
    esac

    # RAR
    case "$MAGIC" in
        526172211a07*)
            echo "RAR"
            return ;;
    esac

    # TAR (GNU)
    MAGIC257=$(dd if="$FILE" bs=1 skip=257 count=6 2>/dev/null | od -A n -t x1 | tr -d ' \n')
    case "$MAGIC257" in
        757374617200*)
            echo "TAR"
            return ;;
    esac

    # SQLite
    case "$MAGIC" in
        53514c69746520666f726d6174*)
            echo "SQLITE"
            return ;;
    esac

    # ISO 9660
    MAGIC32770=$(dd if="$FILE" bs=1 skip=32769 count=5 2>/dev/null | od -A n -t x1 | tr -d ' \n')
    case "$MAGIC32770" in
        4344303031*)
            echo "ISO"
            return ;;
    esac

    # Identify by extension
    EXT="${FILE##*.}"
    EXT_LOWER=$(echo "$EXT" | tr '[:upper:]' '[:lower:]')

    case "$EXT_LOWER" in
        txt|text|log|conf|cfg|ini|md|rst)
            echo "TEXT" ;;
        sh|bash|zsh)
            echo "SHELL" ;;
        py|pyw)
            echo "PYTHON" ;;
        rb)
            echo "RUBY" ;;
        pl|pm)
            echo "PERL" ;;
        js|mjs|cjs)
            echo "JAVASCRIPT" ;;
        ts|tsx)
            echo "TYPESCRIPT" ;;
        html|htm|xhtml)
            echo "HTML" ;;
        xml|svg|xsl)
            echo "XML" ;;
        json)
            echo "JSON" ;;
        yaml|yml)
            echo "YAML" ;;
        csv)
            echo "CSV" ;;
        c|h)
            echo "C_SOURCE" ;;
        cpp|cc|cxx|hpp)
            echo "CPP_SOURCE" ;;
        java)
            echo "JAVA_SOURCE" ;;
        go)
            echo "GO_SOURCE" ;;
        rs)
            echo "RUST_SOURCE" ;;
        php)
            echo "PHP" ;;
        css|scss|sass)
            echo "CSS" ;;
        mp4|m4v)
            echo "MP4" ;;
        mov|qt)
            echo "MOV" ;;
        flv)
            echo "FLV" ;;
        webm)
            echo "WEBM" ;;
        ts|m2ts|mts)
            echo "TS_VIDEO" ;;
        aac)
            echo "AAC" ;;
        m4a)
            echo "M4A" ;;
        wma)
            echo "WMA" ;;
        opus)
            echo "OPUS" ;;
        ico)
            echo "ICO" ;;
        webp)
            echo "WEBP" ;;
        tar)
            echo "TAR" ;;
        lz4)
            echo "LZ4" ;;
        *)
            echo "UNKNOWN" ;;
    esac
}

# Open file by type
open_file() {
    FILE="$1"
    TYPE=$(detect_type "$FILE")

    printf "\033[1;36m[EunOS]\033[0m File: \033[1;33m%s\033[0m  Type: \033[1;32m%s\033[0m\n" "$FILE" "$TYPE"

    case "$TYPE" in
        ELF)
            echo "  Linux ELF executable - check permissions before running"
            echo "  File info:"
            file "$FILE" 2>/dev/null || echo "  (file command not found)"
            ;;

        EXE|DLL)
            echo "  Windows PE executable"
            if command -v wine >/dev/null 2>&1; then
                echo "  Running with Wine..."
                wine "$FILE"
            else
                echo "  Wine is not installed."
                echo "  Install: eunos-install wine"
                echo ""
                echo "  File info:"
                file "$FILE" 2>/dev/null || hexdump -C "$FILE" | head -4
            fi
            ;;

        PDF)
            if command -v mupdf >/dev/null 2>&1; then
                mupdf "$FILE"
            elif command -v evince >/dev/null 2>&1; then
                evince "$FILE"
            elif command -v zathura >/dev/null 2>&1; then
                zathura "$FILE"
            else
                echo "  No PDF viewer. Install: eunos-install mupdf"
                echo "  Trying text extraction..."
                strings "$FILE" | grep -v '^[^[:print:]]' | head -50
            fi
            ;;

        PNG|JPEG|GIF|BMP|TIFF|ICO|WEBP)
            if command -v feh >/dev/null 2>&1; then
                feh "$FILE"
            elif command -v display >/dev/null 2>&1; then
                display "$FILE"
            elif command -v eog >/dev/null 2>&1; then
                eog "$FILE"
            else
                echo "  No image viewer. Install: eunos-install feh"
                ls -lh "$FILE"
                echo "  File size: $(wc -c < "$FILE") bytes"
            fi
            ;;

        MP3|FLAC|OGG|WAV|AAC|M4A|WMA|OPUS)
            if command -v mpv >/dev/null 2>&1; then
                mpv --no-video "$FILE"
            elif command -v ffplay >/dev/null 2>&1; then
                ffplay -nodisp "$FILE"
            elif command -v mplayer >/dev/null 2>&1; then
                mplayer "$FILE"
            elif command -v aplay >/dev/null 2>&1 && [ "$TYPE" = "WAV" ]; then
                aplay "$FILE"
            else
                echo "  No audio player. Install: eunos-install mpv"
            fi
            ;;

        MP4|MKV|AVI|MOV|FLV|WEBM|TS_VIDEO)
            if command -v mpv >/dev/null 2>&1; then
                mpv "$FILE"
            elif command -v ffplay >/dev/null 2>&1; then
                ffplay "$FILE"
            elif command -v mplayer >/dev/null 2>&1; then
                mplayer "$FILE"
            elif command -v vlc >/dev/null 2>&1; then
                vlc "$FILE"
            else
                echo "  No video player. Install: eunos-install mpv"
            fi
            ;;

        ZIP)
            echo "  ZIP archive contents:"
            if command -v unzip >/dev/null 2>&1; then
                unzip -l "$FILE"
                echo ""
                printf "  Extract? [y/N] "
                read ANSWER
                [ "$ANSWER" = "y" ] || [ "$ANSWER" = "Y" ] && unzip "$FILE"
            elif command -v python3 >/dev/null 2>&1; then
                python3 -c "
import zipfile, sys
with zipfile.ZipFile('$FILE') as z:
    for info in z.infolist():
        print(f'  {info.filename:40s} {info.file_size:>10,} bytes')
"
            else
                echo "  No unzip. Install: eunos-install unzip"
            fi
            ;;

        GZIP)
            echo "  GZIP compressed file"
            if command -v gunzip >/dev/null 2>&1; then
                gunzip -l "$FILE" 2>/dev/null || echo "  (No size info)"
                printf "  Extract? [y/N] "
                read ANSWER
                [ "$ANSWER" = "y" ] || [ "$ANSWER" = "Y" ] && gunzip -k "$FILE"
            fi
            ;;

        BZIP2)
            echo "  BZIP2 compressed file"
            printf "  Extract? [y/N] "
            read ANSWER
            [ "$ANSWER" = "y" ] || [ "$ANSWER" = "Y" ] && bunzip2 -k "$FILE"
            ;;

        XZ)
            echo "  XZ compressed file"
            printf "  Extract? [y/N] "
            read ANSWER
            [ "$ANSWER" = "y" ] || [ "$ANSWER" = "Y" ] && xz -dk "$FILE"
            ;;

        7Z)
            echo "  7-Zip archive"
            if command -v 7z >/dev/null 2>&1; then
                7z l "$FILE"
                printf "  Extract? [y/N] "
                read ANSWER
                [ "$ANSWER" = "y" ] || [ "$ANSWER" = "Y" ] && 7z x "$FILE"
            else
                echo "  No 7z. Install: eunos-install 7zip"
            fi
            ;;

        RAR)
            echo "  RAR archive"
            if command -v unrar >/dev/null 2>&1; then
                unrar l "$FILE"
                printf "  Extract? [y/N] "
                read ANSWER
                [ "$ANSWER" = "y" ] || [ "$ANSWER" = "Y" ] && unrar x "$FILE"
            else
                echo "  No unrar. Install: eunos-install unrar"
            fi
            ;;

        TAR)
            echo "  TAR archive contents:"
            tar tf "$FILE" | head -30
            printf "  Extract? [y/N] "
            read ANSWER
            [ "$ANSWER" = "y" ] || [ "$ANSWER" = "Y" ] && tar xf "$FILE"
            ;;

        LZ4)
            echo "  LZ4 compressed file"
            if command -v lz4 >/dev/null 2>&1; then
                printf "  Extract? [y/N] "
                read ANSWER
                [ "$ANSWER" = "y" ] || [ "$ANSWER" = "Y" ] && lz4 -d "$FILE"
            else
                echo "  No lz4. Install: eunos-install lz4"
            fi
            ;;

        SQLITE)
            echo "  SQLite database"
            if command -v sqlite3 >/dev/null 2>&1; then
                echo "  Table list:"
                sqlite3 "$FILE" ".tables"
                echo ""
                echo "  To open sqlite3 shell: sqlite3 $FILE"
                printf "  Open sqlite3 shell? [y/N] "
                read ANSWER
                [ "$ANSWER" = "y" ] || [ "$ANSWER" = "Y" ] && sqlite3 "$FILE"
            else
                echo "  No sqlite3. Install: eunos-install sqlite"
            fi
            ;;

        ISO)
            echo "  ISO disk image"
            if command -v isoinfo >/dev/null 2>&1; then
                isoinfo -d -i "$FILE"
            else
                echo "  File size: $(ls -lh "$FILE" | awk '{print $5}')"
                echo "  Mount: mount -o loop $FILE /mnt"
            fi
            ;;

        TEXT|SHELL|PYTHON|RUBY|PERL|JAVASCRIPT|TYPESCRIPT|HTML|XML|JSON|YAML|CSV|C_SOURCE|CPP_SOURCE|JAVA_SOURCE|GO_SOURCE|RUST_SOURCE|PHP|CSS)
            # Text files
            LINES=$(wc -l < "$FILE" 2>/dev/null || echo "?")
            SIZE=$(wc -c < "$FILE" 2>/dev/null || echo "?")
            echo "  Text file: ${LINES} lines, ${SIZE} bytes"
            echo ""
            if command -v less >/dev/null 2>&1; then
                less "$FILE"
            elif command -v more >/dev/null 2>&1; then
                more "$FILE"
            else
                cat "$FILE"
            fi
            ;;

        UNKNOWN)
            echo "  Unknown file format"
            echo "  Magic bytes:"
            dd if="$FILE" bs=1 count=16 2>/dev/null | od -A x -t x1z | head -3
            echo ""
            echo "  File info:"
            file "$FILE" 2>/dev/null || ls -lh "$FILE"
            echo ""
            printf "  Open as text? [y/N] "
            read ANSWER
            [ "$ANSWER" = "y" ] || [ "$ANSWER" = "Y" ] && less "$FILE" 2>/dev/null || cat "$FILE"
            ;;

        ERROR)
            echo "  Error: Cannot read file"
            ;;
    esac
}

# Main
[ $# -eq 0 ] && usage

case "$1" in
    --list|-l) list_formats ;;
    --version|-v) echo "eunos-open $VERSION" ; exit 0 ;;
    --help|-h) usage ;;
esac

for FILE in "$@"; do
    open_file "$FILE"
    echo ""
done
