#!/bin/sh
# EunOS Boot Selector - Select OS/Recovery Mode at first boot

C_TITLE='\033[1;37;44m'
C_BOX='\033[1;36m'
C_SEL='\033[1;30;46m'
C_OK='\033[1;32m'
C_WARN='\033[1;33m'
C_DIM='\033[2;37m'
C_ACCENT='\033[1;36m'
NC='\033[0m'

# If already in recovery mode, enter directly
if grep -q 'eunos\.recovery=1' /proc/cmdline 2>/dev/null; then
    exec /usr/local/bin/eunos-recovery
fi

TIMEOUT=10
CHOICE=""

draw_selector() {
    clear
    printf "${C_BOX}"
    printf "╔══════════════════════════════════════════════════════════════════╗\n"
    printf "║                                                                  ║\n"
    printf "║    ███████╗██╗   ██╗███╗   ██╗ ██████╗ ███████╗                ║\n"
    printf "║    ██╔════╝██║   ██║████╗  ██║██╔═══██╗██╔════╝                ║\n"
    printf "║    █████╗  ██║   ██║██╔██╗ ██║██║   ██║███████╗                ║\n"
    printf "║    ██╔══╝  ██║   ██║██║╚██╗██║██║   ██║╚════██║                ║\n"
    printf "║    ███████╗╚██████╔╝██║ ╚████║╚██████╔╝███████║                ║\n"
    printf "║    ╚══════╝ ╚═════╝ ╚═╝  ╚═══╝ ╚═════╝ ╚══════╝                ║\n"
    printf "║                     Version 1.0.0  \"Harmony\"                     ║\n"
    printf "╠══════════════════════════════════════════════════════════════════╣\n"
    printf "║                                                                  ║\n"
    printf "║   Select operating system:                                       ║\n"
    printf "║                                                                  ║\n"
    printf "║  ┌────────────────────────────┐  ┌────────────────────────────┐ ║\n"
    printf "║  │                            │  │                            │ ║\n"
    printf "║  │   ${C_OK}[1]  Start EunOS${C_BOX}         │  │   ${C_WARN}[2]  Recovery Mode${C_BOX}        │ ║\n"
    printf "║  │                            │  │                            │ ║\n"
    printf "║  │   Boot in normal mode      │  │   System recovery /        │ ║\n"
    printf "║  │   All features available   │  │   CMD / Calc / Browser     │ ║\n"
    printf "║  │                            │  │                            │ ║\n"
    printf "║  └────────────────────────────┘  └────────────────────────────┘ ║\n"
    printf "║                                                                  ║\n"
    printf "║   ${C_DIM}Current time: $(date '+%Y-%m-%d %H:%M:%S')${C_BOX}                          ║\n"
    printf "║                                                                  ║\n"
    if [ "$1" -gt 0 ]; then
        printf "║   ${C_DIM}Starting EunOS automatically in %d seconds...${C_BOX}              ║\n" "$1"
    else
        printf "║   ${C_WARN}Select: ${C_BOX}                                                      ║\n"
    fi
    printf "║                                                                  ║\n"
    printf "╚══════════════════════════════════════════════════════════════════╝\n"
    printf "${NC}"
}

# Countdown
i=$TIMEOUT
while [ $i -gt 0 ]; do
    draw_selector $i
    # Detect key input during 0.5s wait
    if read -r -t 1 key 2>/dev/null; then
        case "$key" in
            1) CHOICE="1"; break ;;
            2) CHOICE="2"; break ;;
        esac
    fi
    i=$((i - 1))
done

if [ -z "$CHOICE" ]; then
    # Timeout → Start EunOS
    draw_selector 0
    printf "\n  ${C_OK}Starting EunOS...${NC}\n"
    sleep 1
    exec /bin/login -f root
fi

case "$CHOICE" in
    1)
        draw_selector 0
        printf "\n  ${C_OK}Starting EunOS...${NC}\n"
        sleep 1
        exec /bin/login -f root
        ;;
    2)
        exec /usr/local/bin/eunos-recovery
        ;;
esac

# Fallback
exec /bin/login -f root
